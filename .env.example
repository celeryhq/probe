# Agent Eval — Runtime Settings
# Copy to .env and customize

# Browser
AGENT_EVAL_HEADLESS=false              # false = watch the probe live, true = CI mode
AGENT_EVAL_TIMEOUT=300                 # max seconds per agent response

# Recording
AGENT_EVAL_SCREENSHOT_EVERY_STEP=true  # capture screenshot after every action
AGENT_EVAL_RECORD_VIDEO=true           # record WebM video per scenario

# Runner
AGENT_EVAL_PARALLEL=false              # auto-parallelize independent scenarios
AGENT_EVAL_STOP_ON_FAILURE=false       # continue to next scenario on failure
AGENT_EVAL_REPORT_FORMAT=html          # html | json | both

# Output
AGENT_EVAL_OUTPUT_DIR=results           # results directory (pre-created, no mkdir needed)
AGENT_EVAL_OPEN_REPORT=true            # auto-open report after probe

# ── Target Agent Credentials ──────────────
# Referenced in YAML via {{env:VAR_NAME}}
# Auth type: email | oauth | api_key | sso | none
AGENT_TARGET_AUTH_TYPE=email
AGENT_TARGET_EMAIL=test@example.com
AGENT_TARGET_PASSWORD=changeme

# For OAuth:
# AGENT_TARGET_AUTH_TYPE=oauth
# AGENT_TARGET_OAUTH_TOKEN=eyJhbG...

# For API key:
# AGENT_TARGET_AUTH_TYPE=api_key
# AGENT_TARGET_API_KEY=sk-xxx

# For SSO:
# AGENT_TARGET_AUTH_TYPE=sso
# AGENT_TARGET_SSO_URL=https://sso.company.com/saml

# ── Langfuse (optional) — cross-debug agent threads ──────
# Used by the `langfuse` skill (npx langfuse-cli) to pull traces, observations,
# sessions, and scores for the agent under probe. Leave blank to disable.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com   # self-hosted? set your own URL
